{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "Node",
    "jsx": "react-jsx",
    "strict": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "baseUrl": ".",
    "paths": {
      "@game/*": ["game/*"],
      "@ui/*": ["ui/*"],
      "@assets/*": ["assets/*"]
    }
  },
  "include": ["game", "ui", "tests", "main.js"],
  "exclude": ["node_modules"]
}
